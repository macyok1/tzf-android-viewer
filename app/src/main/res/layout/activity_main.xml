<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/ink">

    <FrameLayout android:id="@+id/viewportContainer" android:layout_width="match_parent" android:layout_height="match_parent" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical"
        android:paddingHorizontal="12dp" android:background="@color/panel" android:elevation="8dp">
        <TextView android:id="@+id/projectTitle" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center_vertical" android:textColor="@color/text_primary"
            android:textSize="18sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:gravity="center"
            android:paddingHorizontal="10dp" android:text="СШИВКА" android:textColor="@color/cyan"
            android:background="@color/ink" />
    </LinearLayout>

    <LinearLayout android:id="@+id/compactTools" android:layout_width="44dp" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_marginStart="8dp" android:layout_marginTop="56dp"
        android:orientation="vertical" android:background="@color/panel" android:elevation="7dp">
        <Button android:id="@+id/compactOpen" style="@style/CompactTool" android:layout_width="44dp" android:layout_height="44dp" android:text="＋" android:contentDescription="Добавить TZF"/>
        <Button android:id="@+id/compactFit" style="@style/CompactTool" android:layout_width="44dp" android:layout_height="44dp" android:text="⌂" android:contentDescription="Показать всё"/>
        <Button android:id="@+id/scans" style="@style/CompactTool" android:layout_width="44dp" android:layout_height="44dp" android:text="R/M" android:textSize="10sp" android:contentDescription="Сканы и связки"/>
        <Button android:id="@+id/measure" style="@style/CompactTool" android:layout_width="44dp" android:layout_height="44dp" android:text="◎" android:contentDescription="Измерение"/>
        <Button android:id="@+id/moreTools" style="@style/CompactTool" android:layout_width="44dp" android:layout_height="44dp" android:text="⋯" android:contentDescription="Параметры"/>
    </LinearLayout>

    <ru.tzfviewer.OrientationCubeView android:id="@+id/orientation" android:layout_width="96dp" android:layout_height="96dp"
        android:layout_gravity="top|end" android:layout_marginTop="58dp" android:layout_marginEnd="10dp" />

    <TextView android:id="@+id/status" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|start" android:layout_marginStart="60dp" android:layout_marginBottom="10dp"
        android:maxWidth="280dp" android:padding="7dp" android:background="@color/panel"
        android:text="Добавьте TZF кнопкой ＋" android:textColor="@color/text_secondary" />

    <LinearLayout android:id="@+id/pairCard" android:layout_width="210dp" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end" android:layout_margin="10dp" android:orientation="vertical"
        android:padding="7dp" android:background="@color/panel" android:elevation="8dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ВЫБРАНО ДЛЯ СШИВКИ" android:textSize="10sp" android:textColor="@color/text_secondary" />
        <TextView android:id="@+id/referenceLabel" android:layout_width="match_parent" android:layout_height="34dp" android:gravity="center_vertical" android:text="R  не выбран" android:textColor="@color/cyan" />
        <TextView android:id="@+id/movingLabel" android:layout_width="match_parent" android:layout_height="34dp" android:gravity="center_vertical" android:text="M  не выбран" android:textColor="@color/amber" />
        <Button android:id="@+id/registerScans" style="@style/ToolButton" android:layout_width="match_parent" android:layout_height="42dp" android:text="Точная сшивка" />
        <ProgressBar android:id="@+id/registrationProgress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:indeterminate="true" android:visibility="gone" />
        <Button android:id="@+id/cancelRegistration" style="@style/ToolButton" android:layout_width="match_parent" android:layout_height="40dp" android:text="Отмена" android:visibility="gone" />
    </LinearLayout>

    <LinearLayout android:id="@+id/scanPanel" android:layout_width="match_parent" android:layout_height="220dp"
        android:layout_gravity="bottom" android:orientation="vertical" android:background="@color/panel"
        android:visibility="gone" android:elevation="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="36dp" android:gravity="center_vertical" android:paddingHorizontal="10dp">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_vertical" android:text="СКАНЫ И СВЯЗКИ" android:textColor="@color/text_primary" android:textStyle="bold" />
            <Button android:id="@+id/closeScans" style="@style/CompactTool" android:layout_width="36dp" android:layout_height="36dp" android:text="⌄" />
        </LinearLayout>
        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <ru.tzfviewer.ScanTreePanel android:id="@+id/scanTree" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout android:id="@+id/settingsPanel" android:layout_width="match_parent" android:layout_height="220dp"
        android:layout_gravity="bottom" android:orientation="vertical" android:padding="8dp"
        android:background="@color/panel" android:visibility="gone" android:elevation="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="36dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_vertical" android:text="ПАРАМЕТРЫ СШИВКИ" android:textColor="@color/text_primary" android:textStyle="bold" />
            <Button android:id="@+id/closeSettings" style="@style/CompactTool" android:layout_width="36dp" android:layout_height="36dp" android:text="⌄" />
        </LinearLayout>
        <TextView android:id="@+id/transformSummary" android:layout_width="match_parent" android:layout_height="32dp" android:gravity="center_vertical" android:textColor="@color/amber" android:fontFamily="monospace" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp">
            <EditText android:id="@+id/rmsLimit" style="@style/AxisInput" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:hint="RMS, ед." android:text="3.0" />
            <EditText android:id="@+id/p95Limit" style="@style/AxisInput" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:hint="P95, ед." android:text="8.0" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp">
            <Button android:id="@+id/resetTransform" style="@style/ToolButton" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Сброс" />
            <Button android:id="@+id/saveTransform" style="@style/ToolButton" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Сохранить" />
            <Button android:id="@+id/restoreTransform" style="@style/ToolButton" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Вернуть" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="44dp">
            <Button android:id="@+id/compactProjection" style="@style/ToolButton" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Проекция" />
            <Button android:id="@+id/grid" style="@style/ToolButton" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="Сетка" />
            <Button android:id="@+id/pointSize" style="@style/ToolButton" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="•• 2" />
            <Button android:id="@+id/pointBudget" style="@style/ToolButton" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="150k" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
