<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical"
    android:background="@color/ink" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
        <Button android:id="@+id/backFromSettings" style="@style/CompactTool" android:layout_width="44dp" android:layout_height="44dp" android:text="←" android:contentDescription="К проектам" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_vertical" android:text="Настройки" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="vertical" android:padding="16dp" android:background="@color/panel">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="О приложении" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:id="@+id/appVersion" android:layout_width="match_parent" android:layout_height="36dp" android:gravity="center_vertical" android:textColor="@color/text_secondary" />
        <TextView android:layout_width="match_parent" android:layout_height="36dp" android:gravity="center_vertical" android:text="Канал обновлений: GitHub nightly" android:textColor="@color/text_secondary" />
        <Button android:id="@+id/settingsUpdateApp" style="@style/ToolButton" android:layout_width="match_parent" android:layout_height="48dp" android:text="Проверить обновление" />
        <TextView android:id="@+id/settingsUpdateStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:gravity="center_vertical" android:text="Нажмите, чтобы проверить новую версию" android:textColor="@color/text_secondary" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" android:padding="16dp" android:background="@color/panel">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Хранение сканов" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:id="@+id/storageFolderStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="40dp" android:gravity="center_vertical" android:text="Папка не выбрана" android:textColor="@color/text_secondary" />
        <Button android:id="@+id/selectStorageFolder" style="@style/ToolButton" android:layout_width="match_parent" android:layout_height="48dp" android:text="Выбрать папку хранения" />
    </LinearLayout>
</LinearLayout>
