<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/ink" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Проекты" android:textColor="@color/text_primary" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/appSettings" style="@style/CompactTool"
            android:layout_width="48dp" android:layout_height="48dp" android:text="⚙"
            android:contentDescription="Настройки приложения"/>
    </LinearLayout>
    <Button android:id="@+id/newProject" style="@style/PrimaryAction"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginTop="8dp" android:text="＋ Создать проект"/>
    <TextView android:id="@+id/emptyProjects" android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:gravity="center" android:text="Проектов пока нет\nСоздайте первый проект"
        android:textColor="@color/text_secondary" android:textSize="17sp"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingTop="16dp" android:fillViewport="true">
        <LinearLayout android:id="@+id/projectList" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>
