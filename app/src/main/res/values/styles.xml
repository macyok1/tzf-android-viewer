<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/cyan</item>
        <item name="android:navigationBarColor">@color/ink</item>
        <item name="android:statusBarColor">@color/ink</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="ToolButton" parent="android:style/Widget.Material.Button.Borderless">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="CompactTool" parent="android:style/Widget.Material.Button.Borderless">
        <item name="android:textColor">@color/text_primary</item><item name="android:textSize">17sp</item>
        <item name="android:minWidth">42dp</item><item name="android:minHeight">42dp</item>
        <item name="android:padding">0dp</item><item name="android:background">@color/panel</item>
    </style>
    <style name="AxisInput" parent="android:style/Widget.Material.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:inputType">numberDecimal|numberSigned</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">48dp</item>
    </style>
</resources>
